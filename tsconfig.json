{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "types": [
      "react",
      "react-dom",
      "three"
    ]
  },
  "include": [
    "App.tsx",
    "index.tsx",
    "SRC/**/*",
    "components/**/*",
    "services/**/*",
    "types.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
